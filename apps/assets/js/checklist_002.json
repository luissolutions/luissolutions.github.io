{
        "title": "Audit Checklist",

  "sections": [
    {
      "id": "audit_info",
      "title": "Audit Info",
      "type": "fields",
      "fields": [
        {
          "id": "siteNumber",
          "label": "Site #"
        },
        {
          "id": "location",
          "label": "Location"
        },
        {
          "id": "visitDate",
          "label": "Visit Date",
          "type": "date"
        },
        {
          "id": "managerName",
          "label": "Store Manager Name"
        }
      ]
    },
    {
      "id": "sales_ceiling",
      "title": "Sales Floor Ceiling Type",
      "type": "singleSelect",
      "options": [
        "Wood",
        "Iron",
        "Tile",
        "Drywall"
      ]
    },
    {
      "id": "stock_ceiling",
      "title": "Stockroom Ceiling Type",
      "type": "singleSelect",
      "options": [
        "Wood",
        "Iron",
        "Tile",
        "Drywall"
      ]
    },
    {
      "id": "ceiling_notes",
      "title": "Ceiling Notes",
      "type": "fields",
      "fields": [ 
        {
          "id": "CeilingNotes",
          "label": "Notes",
          "type": "textarea"
        }
      ]
    },
    {
      "id": "sensor_checks",
      "title": "Sensor Checks / Notes",
      "type": "checklist",
      "notes": true,
      "items": [
        {
          "text": "Spot Check Sensors (5)",
          "weight": 0
        },
        {
          "text": "Sensors Not Straight",
          "weight": 4,
          "type": "negative"
        },
        {
          "text": "Sensors Not Level",
          "weight": 4,
          "type": "negative"
        }
      ]
    },
    {
      "id": "insulation",
      "title": "Insulation present in ceiling",
      "type": "singleSelect",
      "options": [
        "YES",
        "NO"
      ]
    },
    {
      "id": "audit_questions",
      "title": "Audit Questions",
      "type": "checklist",
      "items": [
        {
          "text": "J-Hooks installed for cabling",
          "weight": 5
        },
        {
          "text": "6 ft service loops at all sensors",
          "weight": 5
        },
        {
          "text": "Cables dressed properly (sales floor)",
          "weight": 4
        },
        {
          "text": "Cables dressed properly (stockroom)",
          "weight": 4
        },
        {
          "text": "Poles mounted correctly",
          "weight": 5
        },
        {
          "text": "Patch cables labeled",
          "weight": 3
        },
        {
          "text": "Power cords dressed",
          "weight": 2
        },
        {
          "text": "Penetrations properly sleeved",
          "weight": 4
        },
        {
          "text": "Tape removed from floors",
          "weight": 2
        },
        {
          "text": "Rack cables dressed neatly",
          "weight": 3
        }
      ]
    },
    {
      "id": "audit_flags",
      "title": "Audit Issues (Penalties)",
      "type": "checklist",
      "items": [
        {
          "text": "Materials left onsite",
          "weight": 6,
          "type": "negative"
        },
        {
          "text": "Loose or messy cabling",
          "weight": 5,
          "type": "negative"
        },
        {
          "text": "Improper sensor mounting",
          "weight": 8,
          "type": "negative"
        }
      ]
    },
    {
      "id": "final_scoring",
      "title": "Audit Score",
      "type": "scoring",
      "fields": [
        {
          "id": "quality",
          "label": "Quality",
          "max": 40
        },
        {
          "id": "compliance",
          "label": "Compliance",
          "max": 30
        },
        {
          "id": "documentation",
          "label": "Documentation",
          "max": 30
        }
      ]
    },
    {
      "id": "audit_result",
      "title": "Final Result",
      "type": "singleSelect",
      "options": [
        "Pass",
        "Conditional",
        "Fail"
      ]
    },
    {
      "id": "audit_result_notes",
      "title": "Final Notes",
      "type": "fields",
      "fields": [
        {
          "id": "finalNotes",
          "label": "Notes",
          "type": "textarea"
        }
      ]
    }
  ]
}