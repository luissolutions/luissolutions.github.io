{
  "sections": [
    {
      "id": "audit_info",
      "title": "Audit Info",
      "type": "fields",
      "fields": [
        { "id": "auditor", "label": "Auditor Name" },
        { "id": "siteNumber", "label": "Site #" },
        { "id": "date", "label": "Date", "type": "date" }
      ]
    },

    {
      "id": "installation_audit",
      "title": "Installation Audit",
      "type": "checklist",
      "items": [
        { "text": "Proper cable routing" },
        { "text": "Clean rack install" },
        { "text": "Correct labeling" },
        { "text": "Secure mounting" }
      ]
    },

    {
      "id": "violations",
      "title": "Violations",
      "type": "checklist",
      "items": [
        { "text": "Loose cables", "type": "negative", "weight": 10 },
        { "text": "Improper mounting", "type": "negative", "weight": 20 },
        { "text": "Missing labels", "type": "negative", "weight": 10 }
      ]
    },

    {
      "id": "audit_score",
      "title": "Audit Score",
      "type": "scoring",
      "fields": [
        { "id": "quality", "label": "Quality", "max": 40 },
        { "id": "compliance", "label": "Compliance", "max": 30 },
        { "id": "documentation", "label": "Documentation", "max": 30 }
      ]
    },

    {
      "id": "audit_result",
      "title": "Final Result",
      "type": "singleSelect",
      "options": [
        "Pass",
        "Conditional",
        "Fail"
      ]
    }
  ]
}