{
  "sections": [
    {
      "id": "site_info",
      "title": "Section 1 - Site Information",
      "type": "fields",
      "fields": [
        {
          "id": "siteNumber",
          "label": "Site Number"
        },
        {
          "id": "location",
          "label": "Location"
        },
        {
          "id": "qcLead",
          "label": "QC Lead"
        },
        {
          "id": "partnerCompany",
          "label": "Partner Company"
        },
        {
          "id": "leadTech",
          "label": "Lead Tech"
        },
        {
          "id": "techCount",
          "label": "Sensor Count",
          "type": "number"
        },
        {
          "id": "date",
          "label": "Date",
          "type": "date"
        }
      ]
    },
    {
      "id": "pre_deploy_checklist",
      "title": "Section 2 - Pre-Deployment Checklist",
      "type": "checklist",
      "items": [
        {
          "text": "Assign team roles",
          "required": true
        },
        {
          "text": "Ensure crash kit is onsite and validated",
          "required": true,
          "critical": true
        },
        {
          "text": "Log into iPad and escalate issues",
          "required": true
        },
        {
          "text": "Confirm 72 test cards present",
          "required": true
        },
        {
          "text": "Validate inventory matches BOM",
          "required": true,
          "critical": true
        },
        {
          "text": "Verify tech attire and PPE",
          "required": true
        },
        {
          "text": "Confirm required tools available",
          "required": true,
          "critical": true
        }
      ],
      "notes": true
    },
    {
      "id": "pre_deployment_daily",
      "title": "Section 3 - Pre-Deployment Activities",
      "type": "checklist",
      "items": [
        {
          "text": "QC Lead briefs team",
          "required": true
        },
        {
          "text": "Connect with site POC",
          "required": true
        },
        {
          "text": "Verify no deployment impediments",
          "required": true
        },
        {
          "text": "Ensure materials onsite",
          "required": true,
          "critical": true
        },
        {
          "text": "Verify lifts operational and safe",
          "required": true,
          "critical": true
        },
        {
          "text": "Report issues via SmartSheets",
          "required": true
        }
      ],
      "notes": true
    },
    {
      "id": "start_shift",
      "title": "Section 4 - Start of Shift",
      "type": "checklist",
      "items": [
        {
          "text": "Confirm vendor check-ins submitted",
          "required": true
        },
        {
          "text": "Submit QC pre-install Smartsheet",
          "required": true
        },
        {
          "text": "Conduct walkthrough and document issues",
          "required": true,
          "critical": true
        },
        {
          "text": "Confirm doors locked and alarms armed",
          "required": true,
          "critical": true
        },
        {
          "text": "Verify lift operation and PPE awareness",
          "required": true
        }
      ],
      "notes": true
    },
    {
      "id": "end_shift",
      "title": "Section 5 - End of Shift",
      "type": "checklist",
      "items": [
        {
          "text": "Racks returned to original positions",
          "required": true
        },
        {
          "text": "Trash removed and cleaned",
          "required": true
        },
        {
          "text": "Cables secured",
          "required": true
        },
        {
          "text": "Egress paths clear",
          "required": true,
          "critical": true
        },
        {
          "text": "Lifts returned and charging",
          "required": true
        },
        {
          "text": "Store areas clean and organized",
          "required": true
        },
        {
          "text": "Confirm cameras and speakers working",
          "required": true,
          "critical": true
        },
        {
          "text": "Confirm Smartsheet check-in complete",
          "required": true
        },
        {
          "text": "Submit QC post-install Smartsheet",
          "required": true
        }
      ],
      "notes": true
    },
    {
      "id": "team_understanding",
      "title": "Section 6 - Partner Team Understanding",
      "type": "matrix",
      "rows": [
        "Lead Tech",
        "Crew"
      ],
      "columns": [
        "Strong",
        "Moderate",
        "Needs Coaching"
      ]
    },
    {
      "id": "final_scoring",
      "title": "Section 7 - Final Evaluation",
      "type": "scoring",
      "fields": [
        {
          "id": "installationQuality",
          "label": "Installation Quality",
          "max": 30
        },
        {
          "id": "sensorSkill",
          "label": "Sensor Installation Skill",
          "max": 25
        },
        {
          "id": "documentation",
          "label": "Documentation & Deliverables",
          "max": 15
        },
        {
          "id": "toolsPrep",
          "label": "Tools & Preparedness",
          "max": 10
        },
        {
          "id": "workPace",
          "label": "Work Pace & Efficiency",
          "max": 10
        },
        {
          "id": "communication",
          "label": "Communication & Professionalism",
          "max": 10
        }
      ],
      "totalMax": 100
    },
    {
      "id": "qc_concerns",
      "title": "Section 8 - QC Concerns",
      "type": "checklist",
      "items": [
        {
          "text": "Missing required tools",
          "critical": true
        },
        {
          "text": "Careless or rushed work",
          "critical": true
        },
        {
          "text": "Sensor install issues",
          "critical": true
        },
        {
          "text": "Workmanship issues",
          "critical": true
        },
        {
          "text": "Communication concerns"
        },
        {
          "text": "Cannot demonstrate cable testing",
          "critical": true
        }
      ]
    },
    {
      "id": "recommendations",
      "title": "Section 9 - Next Site Recommendation",
      "type": "singleSelect",
      "options": [
        "Team can perform independently",
        "Team requires remote QC",
        "Team requires onsite QC",
        "Team requires reevaluation - major concerns"
      ]
    },
    {
      "id": "final_notes",
      "title": "Section 10 - Final Notes",
      "type": "fields",
      "fields": [
        {
          "id": "strengths",
          "label": "Strengths",
          "type": "textarea"
        },
        {
          "id": "gaps",
          "label": "Gaps / Training Needs",
          "type": "textarea"
        },
        {
          "id": "corrections",
          "label": "Corrections Provided",
          "type": "textarea"
        }
      ]
    }
  ]
}