{
  "sections": [

    {
      "id": "site_info",
      "title": "Site / Deployment Information",
      "type": "fields",
      "fields": [
        { "id": "siteNumber", "label": "Site #" },
        { "id": "location", "label": "Location" },
        { "id": "totalNights", "label": "Total Nights to Complete", "type": "number" },
        { "id": "date", "label": "Date", "type": "date" },
        { "id": "qcLead", "label": "Telaid QC Lead" },
        { "id": "partnerCompany", "label": "Partner Company Name" },
        { "id": "leadTech", "label": "Lead Technician Name" },
        { "id": "additionalTechs", "label": "Names of Additional Technicians On Site" },
        { "id": "installSummary", "label": "Install Summary (1–6 sentences)", "type": "textarea" }
      ]
    },

    {
      "id": "qc_preparedness",
      "title": "QC Preparedness",
      "type": "checklist",
      "items": [
        { "text": "Reviewed RADAR IDG/SOW and installation standards" },
        { "text": "Understand sensor mounting requirements (hardware, leveling, orientation)" },
        { "text": "Understand structured cabling standards" },
        { "text": "Understand required deliverables + submission expectations" },
        { "text": "Confirmed expectations with PMO / scope" }
      ]
    },

    {
      "id": "predeployment_daily",
      "title": "Pre-Deployment Activities (Daily)",
      "type": "checklist",
      "items": [
        { "text": "Connect with site POC and confirm deployment awareness" },
        { "text": "Walk store and verify no impediments" },
        { "text": "Ensure materials are on site" },
        { "text": "Verify lifts delivered and operational" },
        { "text": "Report issues to program team" }
      ]
    },

    {
      "id": "start_shift",
      "title": "Start of Shift (Each Night)",
      "type": "checklistMultiDay",
      "items": [
        { "text": "Confirm vendor check-ins submitted" },
        { "text": "Submit QC pre-install forms" },
        { "text": "Start-of-night walkthrough", "critical": true },
        { "text": "Confirm doors locked + alarms armed", "critical": true },
        { "text": "Verify lift operation + PPE" }
      ]
    },

    {
      "id": "end_shift",
      "title": "End of Shift (Each Night)",
      "type": "checklistMultiDay",
      "items": [
        { "text": "Racks returned to position" },
        { "text": "Trash removed / cleaned" },
        { "text": "Cables secured" },
        { "text": "Egress paths clear", "critical": true },
        { "text": "Lifts returned + charging" },
        { "text": "Store areas reset" },
        { "text": "Cameras + speakers verified", "critical": true },
        { "text": "Vendor Smartsheet submitted" },
        { "text": "QC Post-Install submitted" }
      ]
    },

    {
      "id": "night1_predeployment",
      "title": "Pre-Deployment Activities (Night 1)",
      "type": "checklist",
      "items": [
        { "text": "Assign team roles" },
        { "text": "Ensure crash kit is on-site and verified" },
        { "text": "Log into iPad and escalate issues" },
        { "text": "Verify 72 test cards present" },
        { "text": "Validate inventory vs BOM" },
        { "text": "Check hand scanner" },
        { "text": "Confirm tools available (3D Measure, Certifier)" }
      ]
    },

    {
      "id": "night1_status",
      "title": "End of Night 1 – Status",
      "type": "checklist",
      "notes": true,
      "items": [
        { "text": "Inventory / BOM complete" },
        { "text": "Measurements / Layout complete" },
        { "text": "Controller / Rack / Network online" },
        { "text": "Rack standards reviewed" },
        { "text": "Cable pathway standards reviewed" },
        { "text": "Sensor install reviewed" },
        { "text": "Tool usage reviewed" },
        { "text": "Documentation standards reviewed" }
      ]
    },

    {
      "id": "night1_progress",
      "title": "Night 1 Progress",
      "type": "counter",
      "fields": [
        { "label": "Cables Run", "id": "n1_cables_run", "targetId": "n1_cables_total" },
        { "label": "Terminations", "id": "n1_term_done", "targetId": "n1_term_total" },
        { "label": "Poles Hung", "id": "n1_poles_done", "targetId": "n1_poles_total" },
        { "label": "Brackets Installed", "id": "n1_brackets_done", "targetId": "n1_brackets_total" },
        { "label": "Sensors Mounted", "id": "n1_sensors_done", "targetId": "n1_sensors_total" }
      ]
    },

    {
      "id": "final_scoring",
      "title": "End-of-Week Partner Evaluation",
      "type": "scoring",
      "fields": [
        { "id": "install_quality", "label": "Installation Quality", "max": 30 },
        { "id": "sensor_skill", "label": "Sensor Installation Skill", "max": 25 },
        { "id": "documentation", "label": "Documentation & Deliverables", "max": 15 },
        { "id": "tools", "label": "Tools & Preparedness", "max": 10 },
        { "id": "pace", "label": "Work Pace & Efficiency", "max": 10 },
        { "id": "communication", "label": "Communication & Professionalism", "max": 10 }
      ]
    },

    {
      "id": "qc_flags",
      "title": "QC Flags",
      "type": "checklist",
      "items": [
        { "text": "Missing required tools" },
        { "text": "Careless / rushed work" },
        { "text": "Sensor install issues" },
        { "text": "Workmanship issues" },
        { "text": "Communication issues" },
        { "text": "Cannot demonstrate cable testing" }
      ]
    },

    {
      "id": "final_recommendation",
      "title": "Final Recommendation",
      "type": "singleSelect",
      "options": [
        "Fully Certified",
        "Certified – Minor Coaching",
        "Conditional – Training Required",
        "Not Approved"
      ]
    }

  ]
}