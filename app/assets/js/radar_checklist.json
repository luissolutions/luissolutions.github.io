          "max": 10
        },
        {
          "id": "communication",
          "label": "Communication & Professionalism",
          "max": 10
        }
      ],
      "totalMax": 100
    },
    {
      "id": "qc_concerns",
      "title": "Section 8 - QC Concerns",
      "type": "checklist",
      "items": [
        {
          "text": "Missing required tools",
          "critical": true
        },
        {
          "text": "Careless or rushed work",
          "critical": true
        },
        {
          "text": "Sensor install issues",
          "critical": true
        },
        {
          "text": "Workmanship issues",
          "critical": true
        },
        {
          "text": "Communication concerns"
        },
        {
          "text": "Cannot demonstrate cable testing",
          "critical": true
        }
      ]
    },
    {
      "id": "recommendations",
      "title": "Section 9 - Next Site Recommendation",
