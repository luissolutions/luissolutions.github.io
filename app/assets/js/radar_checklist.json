{
  "program": "RADAR QC Deployment",
  "version": "3.2-per-item",

"nights": [
  { "id": "1", "name": "Night 1" },
  { "id": "2", "name": "Night 2" },
  { "id": "3", "name": "Night 3" },
  { "id": "4", "name": "Night 4" },
  { "id": "5", "name": "Final Night" }
],

  "metaFields": [
    { "id": "siteNumber", "label": "Site #", "type": "text" },
    { "id": "siteLocation", "label": "Location", "type": "text" },
    { "id": "dateField", "label": "Date", "type": "date" },
    { "id": "qcLead", "label": "QC Lead", "type": "text" },
    { "id": "partnerCompany", "label": "Partner Company", "type": "text" },
    { "id": "leadTech", "label": "Lead Technician", "type": "text" },
    { "id": "techNames", "label": "Technicians On Site", "type": "textarea" },
    { "id": "installSummary", "label": "Install Summary", "type": "textarea" }
  ],

  "qcAcknowledgement": {
    "items": [
      { "text": "Reviewed RADAR IDG/SOW and installation standards", "persistent": true },
      { "text": "Understands sensor mounting requirements", "persistent": true },
      { "text": "Understands structured cabling standards", "persistent": true },
      { "text": "Understands required deliverables", "persistent": true },
      { "text": "Confirmed expectations with PMO / scope", "persistent": true },
      { "text": "Completed QC Lead awareness training", "persistent": true }
    ],
    "notesField": { "id": "qcAckNotes", "label": "Notes" }
  },

  "preDeployment": {
    "items": [
      { "text": "QC Lead briefed team on plan", "persistent": false },
      { "text": "Connected with site POC", "persistent": false },
      { "text": "Store walkthrough completed", "persistent": false },
      { "text": "Materials confirmed on site", "persistent": false },
      { "text": "Lifts delivered and operational", "persistent": false },
      { "text": "Issues reported to program team", "persistent": false }
    ],
    "notesField": { "id": "preDeployNotes", "label": "Notes" }
  },

  "dailyProgress": {
    "statusFields": [
      {
        "id": "inventoryStatus",
        "label": "Inventory / BOM",
        "options": ["Complete", "Issues", "Not Started"]
      },
      {
        "id": "measurementStatus",
        "label": "Measurements / Layout",
        "options": ["Complete", "Issues", "Not Started"]
      },
      {
        "id": "networkStatus",
        "label": "Controller / Rack / Network",
        "options": ["Verified", "Issues", "N/A"]
      }
    ],
    "counters": [
      { "id": "cablesRun", "label": "Cables Run", "targetId": "cablesTotal" },
      { "id": "terminations", "label": "Terminations", "targetId": "terminationsTotal" },
      { "id": "polesHung", "label": "Poles Hung", "targetId": "polesTotal" },
      { "id": "bracketsInstalled", "label": "Brackets Installed", "targetId": "bracketsTotal" },
      { "id": "sensorsMounted", "label": "Sensors Mounted", "targetId": "sensorsTotal" }
    ],
    "notesFields": [
      { "id": "issues", "label": "Issues / Corrections" },
      { "id": "escalations", "label": "Escalations" },
      { "id": "materials", "label": "Missing Materials" }
    ]
  },

  "dailyTraining": {
    "items": [
      { "text": "Rack/backboard installation reviewed", "persistent": false },
      { "text": "Cable pathway standards reviewed", "persistent": false },
      { "text": "Sensor bracket install reviewed", "persistent": false },
      { "text": "Lift operation and PPE reviewed", "persistent": false },
      { "text": "Tool usage reviewed", "persistent": false },
      { "text": "Documentation expectations reviewed", "persistent": false }
    ],
    "understandingFields": [
      {
        "id": "leadUnderstanding",
        "label": "Lead Tech",
        "options": ["Strong", "Moderate", "Needs Coaching"]
      },
      {
        "id": "crewUnderstanding",
        "label": "Crew",
        "options": ["Strong", "Moderate", "Needs Coaching"]
      }
    ],
    "notesField": { "id": "trainingNotes", "label": "Notes" }
  },

  "safetyStoreProtection": {
    "items": [
      { "text": "Doors locked and alarms armed", "persistent": false },
      { "text": "No avoidable damage occurred", "persistent": false },
      { "text": "Debris managed and paths clear", "persistent": false }
    ],
    "notesFields": [
      { "id": "damage", "label": "Start-of-Night Damage" },
      { "id": "incidents", "label": "Incidents Today" }
    ]
  },

  "dailyProtocol": {
    "items": [
      { "text": "Pre-install check-in completed", "persistent": false },
      { "text": "QC pre-install form submitted", "persistent": false },
      { "text": "Start-of-night walkthrough", "persistent": false },
      { "text": "Doors locked and alarms armed", "persistent": false },
      { "text": "Lift safety validated", "persistent": false },
      { "text": "Cleanup completed", "persistent": false },
      { "text": "End-of-night walkthrough completed", "persistent": false },
      { "text": "QC post-install form submitted", "persistent": false }
    ],
    "notesField": { "id": "protocolNotes", "label": "Notes" }
  },

  "finalEvaluation": {
    "thresholds": {
      "fullyCertified": 90,
      "minorCoaching": 75,
      "conditional": 60
    },
    "scoring": [
      { "id": "quality", "name": "Quality of Work", "max": 30 },
      { "id": "efficiency", "name": "Efficiency", "max": 20 },
      { "id": "training", "name": "Training Retention", "max": 20 },
      { "id": "safety", "name": "Safety Compliance", "max": 15 },
      { "id": "communication", "name": "Communication", "max": 15 }
    ],
    "recommendationOptions": [
      "Auto (based on score)",
      "Fully Certified",
      "Certified – Minor Coaching",
      "Conditional",
      "Not Approved"
    ],
    "effectivenessForecast": {
      "fields": [
        {
          "id": "futurePerformance",
          "label": "Future Performance",
          "options": ["High", "Moderate", "Low"]
        }
      ]
    },
    "flags": [
      { "text": "Repeated quality issues", "persistent": false },
      { "text": "Safety concerns observed", "persistent": false }
    ],
    "notesFields": [
      { "id": "strengths", "label": "Strengths" },
      { "id": "gapsTraining", "label": "Gaps / Training Needed" },
      { "id": "nextSteps", "label": "Recommended Next Steps" }
    ]
  },

  "emailExport": {
    "subjectTemplate": "RADAR QC – Site {{siteNumber}} – {{partnerCompany}} – {{nightNumber}}"
  }
}