        {
          "id": "siteNumber",
          "label": "Site Number"
        },
        {
          "id": "location",
          "label": "Location"
        },
        {
          "id": "qcLead",
          "label": "QC Lead"
        },
        {
          "id": "partnerCompany",
          "label": "Partner Company"
        },
        {
          "id": "leadTech",
          "label": "Lead Tech"
        },
        {
          "id": "techCount",
          "label": "Sensor Count",
          "type": "number"
        },
        {
          "id": "date",
          "label": "Date",
          "type": "date"
        }
      ]
    },
    {
      "id": "pre_deploy_checklist",
      "title": "Pre-Deployment Activities",
      "type": "checklist",
      "items": [
        {
          "text": "Assign team roles: Inventory, Cablers, Rack Installers, Clinton Pole Assembly, Photo Documentation, Form Submission, Cleanup, and Door Arming ",
          "required": true
        },
        {
          "text": "Ensure the crash kit is on-site (brought by the team or shipped to the site) Inventory kit and validate all items are onsite, if something is missing have partner complete SmartSheet forms for items needed.",
          "required": true,
          "critical": true
        },
        {
          "text": "Log into the iPad; escalate issues immediately. ",
          "required": true
        },
        {
          "text": "Confirm presence of seventy-two test card box. Count and confirm all 72 cards are present.  ",
          "required": true
        },
        {
          "text": "Validate that inventory matches the Bill of Materials (BOM).",
          "required": true,
          "critical": true
        },
        {
          "text": "Confirm partner has installation tools (3D Measure, Level III Cable Certifier). Escalate if missing",
          "required": true
        },
        {
          "text": "Confirm required tools available",
          "required": true,
          "critical": true
        }
      ],
      "notes": true
    },
    {
      "id": "pre_deployment_daily",
      "title": "Pre-Deployment Activities (Daily - Performed by Lead Tech w/ QC Oversite)",
      "type": "checklist",
      "items": [
        {
          "text": "QC Lead briefs team lead on day's activities, expectations and feedback on progress (pre or post shift)",
          "required": true
        },
        {
          "text": "Connect with site POC, conduct an overview of the weeks activities, confirm store personnel are aware of the deployment.",
          "required": true
        },
        {
          "text": "Walk through the store and verify there are no impediments to the deployment.",
          "required": true
        },
        {
          "text": "Ensure materials onsite",
          "required": true,
          "critical": true
        },
        {
          "text": "Verify lifts are delivered, charged, operational, check for leaks, and plugged in as needed.",
          "required": true,
          "critical": true
        },
        {
          "text": "Report issues via SmartSheets",
          "required": true
        }
      ],
      "notes": true
    },
    {
      "id": "start_shift",
      "title": "Daily Responsibilities (Every Night Onsite – Start of Shift) ",
      "type": "checklist",
      "items": [
        {
          "text": "Confirm vendor check-ins submitted",
          "required": true
        },
        {
          "text": "Submit QC pre-install Smartsheet",
          "required": true
        },
        {
          "text": "Conduct a start-of-night walkthrough: document any broken speakers, cameras, or fixtures. Include fixtures in warehouse/BOH that are not being used.",
          "required": true,
          "critical": true
        },
        {
          "text": "Confirm doors locked and alarms armed",
          "required": true,
          "critical": true
        },
        {
          "text": "Verify lift operation and PPE awareness",
          "required": true
        }
      ],
      "notes": true
    },
    {
      "id": "end_shift",
      "title": "Daily Responsibilities (Every Night Onsite - End of Shift) ",
      "type": "checklist",
      "items": [
        {
          "text": "Racks returned to original positions",
          "required": true
        },
        {
          "text": "Trash is removed; cable clippings and dust are swept up.",
          "required": true
        },
        {
          "text": "Cables are neatly secured.",
          "required": true
        },
        {
          "text": "Egress paths clear",
          "required": true,
          "critical": true
        },
        {
          "text": "Lifts are returned to their designated location and charging. ",
          "required": true
        },
        {
          "text": "Front and back of house areas are clear; materials stored neatly where originally found, or as directed by the MOD on night one.",
          "required": true
        },
        {
          "text": "Confirm with MOD that cameras and speakers are working. ",
          "required": true,
          "critical": true
        },
        {
          "text": "Confirm the vendor's Smartsheet check-in is complete by 5:00 AM",
          "required": true
        },
        {
          "text": "Submit the QC Post-Install Smartsheet, including any coaching notes or corrective actions",
          "required": true
        }
      ],
      "notes": true
    },
    {
      "id": "team_understanding",
      "title": "Partner Team Understanding",
      "type": "matrix",
      "rows": [
        "Lead Tech",
        "Crew"
      ],
      "columns": [
        "Strong",
        "Moderate",
        "Needs Coaching"
      ]
    },
    {
