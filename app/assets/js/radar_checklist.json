{
  "sections": [
    {
      "id": "site",
      "title": "Site Info",
      "type": "fields",
      "fields": [
        { "id": "siteNumber", "label": "Site #" },
        { "id": "location", "label": "Location" },
        { "id": "date", "label": "Date", "type": "date" },
        { "id": "qcLead", "label": "QC Lead" },
        { "id": "partner", "label": "Partner Company" },
        { "id": "leadTech", "label": "Lead Tech" },
        { "id": "sensorTotal", "label": "Total Sensors", "type": "number" }
      ]
    },

    {
      "id": "daily_check",
      "title": "Daily QC Checklist",
      "type": "checklist",
      "notes": true,
      "items": [
        { "text": "Checked in / forms submitted" },
        { "text": "Site walkthrough complete" },
        { "text": "Materials verified" },
        { "text": "Lifts working / PPE used" },
        { "text": "Cables installed cleanly" },
        { "text": "Sensors mounted correctly" },
        { "text": "Work area cleaned" },
        { "text": "End-of-day forms submitted" }
      ]
    },

    {
      "id": "production",
      "title": "Production Tracking",
      "type": "fields",
      "fields": [
        { "id": "cables", "label": "Cables Run" },
        { "id": "sensors", "label": "Sensors Installed" }
      ]
    },

    {
      "id": "evaluation",
      "title": "Evaluation",
      "type": "scoring",
      "fields": [
        { "id": "quality", "label": "Quality", "max": 40 },
        { "id": "compliance", "label": "Compliance", "max": 30 },
        { "id": "documentation", "label": "Documentation", "max": 30 }
      ]
    },

    {
      "id": "issues",
      "title": "Issues / Flags",
      "type": "checklist",
      "items": [
        { "text": "Missing tools", "type": "negative", "weight": 5 },
        { "text": "Bad workmanship", "type": "negative", "weight": 10 },
        { "text": "Sensor issues", "type": "negative", "weight": 10 },
        { "text": "Communication issues", "type": "negative", "weight": 5 }
      ]
    },

    {
      "id": "notes",
      "title": "Notes",
      "type": "fields",
      "fields": [
        { "id": "summary", "label": "Summary", "type": "textarea" }
      ]
    },

    {
      "id": "recommendation",
      "title": "Final Result",
      "type": "singleSelect",
      "options": [
        "Pass",
        "Pass w/ Notes",
        "Needs Work",
        "Fail"
      ]
    }
  ]
}